<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/header_bg"
    android:clipToPadding="false"
    android:descendantFocusability="afterDescendants"
    android:paddingBottom="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="8dp">

        <!-- Sheet handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="#FF666666"
            android:backgroundTint="#FF666666"/>

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Radio station list URL"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <EditText
                android:id="@+id/edit_feed_url"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="textUri"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:hint="https://example.com/streams.json"
                android:singleLine="true"
                android:background="@android:color/transparent"
                android:textSize="13sp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"/>

            <Button
                android:id="@+id/btn_reset_url"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="↺"
                android:textSize="16sp"
                android:padding="0dp"
                android:backgroundTint="@color/btn_inactive"
                android:textColor="@color/text_primary"
                style="@style/Widget.MaterialComponents.Button"/>

        </LinearLayout>

        <!-- Divider under URL field -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/text_secondary"
            android:alpha="0.3"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_reload_feed"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="↻  Reload List"
            android:textSize="14sp"
            android:backgroundTint="@color/btn_live"
            android:textColor="@color/text_on_accent"
            android:layout_marginBottom="24dp"
            style="@style/Widget.MaterialComponents.Button"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ad Detection Algorithm"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="4dp"/>

        <Spinner
            android:id="@+id/spinner_algorithm"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="24dp"/>

        <!-- ================================================================= -->
        <!-- Threshold (hidden when algorithm has no threshold param)          -->
        <!-- ================================================================= -->
        <LinearLayout
            android:id="@+id/layout_threshold_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Game Energy Threshold"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:textAllCaps="true"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/text_threshold_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:minWidth="40dp"
                android:gravity="end"/>

            <Button
                android:id="@+id/btn_reset_threshold"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:text="↺"
                android:textSize="16sp"
                android:padding="0dp"
                android:backgroundTint="@color/btn_inactive"
                android:textColor="@color/text_primary"
                style="@style/Widget.MaterialComponents.Button"/>

        </LinearLayout>

        <SeekBar
            android:id="@+id/seek_threshold"
            android:focusable="true"
            android:background="@drawable/seekbar_focus_bg"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:minHeight="48dp"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="100"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="350"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:gravity="end"/>

        </LinearLayout>

        </LinearLayout><!-- end layout_threshold_row -->

        <!-- ================================================================= -->
        <!-- Ads volume                                                         -->
        <!-- ================================================================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ads Volume"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:textAllCaps="true"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/text_ads_volume_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:minWidth="44dp"
                android:gravity="end"/>

            <Button
                android:id="@+id/btn_reset_ads_volume"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:text="↺"
                android:textSize="16sp"
                android:padding="0dp"
                android:backgroundTint="@color/btn_inactive"
                android:textColor="@color/text_primary"
                style="@style/Widget.MaterialComponents.Button"/>

        </LinearLayout>

        <SeekBar
            android:id="@+id/seek_ads_volume"
            android:focusable="true"
            android:background="@drawable/seekbar_focus_bg"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:minHeight="48dp"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0%"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="100%"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:gravity="end"/>

        </LinearLayout>

        <!-- ================================================================= -->
        <!-- Poll interval                                                      -->
        <!-- ================================================================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Game Data Poll Interval"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:textAllCaps="true"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/text_poll_interval_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:minWidth="44dp"
                android:gravity="end"/>

            <Button
                android:id="@+id/btn_reset_poll_interval"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:text="↺"
                android:textSize="16sp"
                android:padding="0dp"
                android:backgroundTint="@color/btn_inactive"
                android:textColor="@color/text_primary"
                style="@style/Widget.MaterialComponents.Button"/>

        </LinearLayout>

        <SeekBar
            android:id="@+id/seek_poll_interval"
            android:focusable="true"
            android:background="@drawable/seekbar_focus_bg"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:minHeight="48dp"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="1s"
                android:textSize="11sp" android:textColor="@color/text_secondary"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="30s"
                android:textSize="11sp" android:textColor="@color/text_secondary"
                android:gravity="end"/>
        </LinearLayout>

        <!-- ================================================================= -->
        <!-- API delay                                                          -->
        <!-- ================================================================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Game Data Delay"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:textAllCaps="true"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/text_api_delay_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:minWidth="44dp"
                android:gravity="end"/>

            <Button
                android:id="@+id/btn_reset_api_delay"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:text="↺"
                android:textSize="16sp"
                android:padding="0dp"
                android:backgroundTint="@color/btn_inactive"
                android:textColor="@color/text_primary"
                style="@style/Widget.MaterialComponents.Button"/>

        </LinearLayout>

        <SeekBar
            android:id="@+id/seek_api_delay"
            android:focusable="true"
            android:background="@drawable/seekbar_focus_bg"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:minHeight="48dp"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="0s"
                android:textSize="11sp" android:textColor="@color/text_secondary"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="120s"
                android:textSize="11sp" android:textColor="@color/text_secondary"
                android:gravity="end"/>
        </LinearLayout>

        <!-- Auto-start audio                                                   -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto-start audio"
                    android:textSize="14sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Autoplay when game is underway"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>
            <Switch
                android:id="@+id/switch_auto_start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"/>
        </LinearLayout>

        <!-- ================================================================= -->
        <!-- Logging enable/disable                                            -->
        <!-- ================================================================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Log audio stats to file"
                    android:textSize="14sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Writes CSV to external storage"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"/>

            </LinearLayout>

            <Switch
                android:id="@+id/switch_logging"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"/>

        </LinearLayout>

        <!-- ================================================================= -->
        <!-- Audio Stats Log Files                                             -->
        <!-- ================================================================= -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Audio Stats Log Files"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/text_log_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="12dp"/>

        <!-- Log action buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_share_log"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="⇧ Share"
                android:textSize="12sp"
                android:backgroundTint="@color/btn_live"
                android:textColor="@color/text_on_accent"
                style="@style/Widget.MaterialComponents.Button"/>

            <!-- not really working, so hide it with "gone" -->
            <Button
                android:visibility="gone"
                android:id="@+id/btn_open_log_dir"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:text="📂 Browse"
                android:textSize="12sp"
                android:backgroundTint="@color/btn_inactive"
                android:textColor="@color/text_primary"
                style="@style/Widget.MaterialComponents.Button"/>

            <Button
                android:id="@+id/btn_delete_logs"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="🗑 Delete"
                android:textSize="12sp"
                android:backgroundTint="@color/btn_stop"
                android:textColor="@color/text_on_accent"
                style="@style/Widget.MaterialComponents.Button"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
