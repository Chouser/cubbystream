<?xml version="1.0" encoding="utf-8"?>
<!--
  Layout structure:
    TOP BAR      — title, subtitle, playback status, energy meter
    MIDDLE       — Skip to Live + Stop (secondary controls)
    BOTTOM BAR   — Pause | Resume side-by-side, then Game/Ads/Auto row
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- ===================================================================== -->
    <!-- TOP BAR: stream info + status + energy meter                          -->
    <!-- ===================================================================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/header_bg"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:elevation="4dp">

        <!-- Title row -->
        <TextView
            android:id="@+id/text_player_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:ellipsize="end"
            android:maxLines="1"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/text_player_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="12dp"/>

        <!-- Playback state -->
        <TextView
            android:id="@+id/text_playback_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connecting…"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="6dp"/>

        <!-- Volume mode label -->
        <TextView
            android:id="@+id/text_volume_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🤖 Auto → detecting…"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="10dp"/>

        <!-- Energy meter label -->
        <TextView
            android:id="@+id/text_energy_level"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Level: —  |  Threshold: 0.0120"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp"/>

        <!-- Energy bar: green = crowd noise present, red = silence/ads -->
        <ProgressBar
            android:id="@+id/progress_energy"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:max="100"
            android:progress="0"/>

    </LinearLayout>

    <!-- ===================================================================== -->
    <!-- MIDDLE: Skip to Live + Stop                                           -->
    <!-- ===================================================================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="24dp">

        <Button
            android:id="@+id/btn_skip_to_live"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="⏭  Skip to Live"
            android:textSize="15sp"
            android:backgroundTint="@color/btn_live"
            android:textColor="@color/text_on_accent"
            style="@style/Widget.MaterialComponents.Button"/>

        <Button
            android:id="@+id/btn_stop"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="■  Stop"
            android:textSize="15sp"
            android:backgroundTint="@color/btn_stop"
            android:textColor="@color/text_on_accent"
            style="@style/Widget.MaterialComponents.Button"/>

    </LinearLayout>

    <!-- ===================================================================== -->
    <!-- BOTTOM BAR: Pause/Resume, then Game/Ads/Auto                         -->
    <!-- ===================================================================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bottom_bar_bg"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="20dp"
        android:elevation="4dp">

        <!-- Pause and Resume side-by-side so they're in the same region
             but clearly labelled — large enough to hit easily, distinct colours -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_pause"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="⏸  Pause"
                android:textSize="17sp"
                android:textStyle="bold"
                android:backgroundTint="@color/btn_pause"
                android:textColor="@color/text_on_accent"
                style="@style/Widget.MaterialComponents.Button"/>

            <Button
                android:id="@+id/btn_resume"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="▶  Resume"
                android:textSize="17sp"
                android:textStyle="bold"
                android:backgroundTint="@color/btn_resume"
                android:textColor="@color/text_on_accent"
                style="@style/Widget.MaterialComponents.Button"/>

        </LinearLayout>

        <!-- Volume mode selector: three mutually exclusive buttons.
             Active button is full opacity; inactive at 45%. -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VOLUME MODE"
            android:textSize="10sp"
            android:textColor="@color/text_secondary"
            android:letterSpacing="0.15"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_mode_game"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:text="🔊 Game"
                android:textSize="13sp"
                android:backgroundTint="@color/btn_game"
                android:textColor="@color/text_on_accent"
                style="@style/Widget.MaterialComponents.Button"/>

            <Button
                android:id="@+id/btn_mode_ads"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp"
                android:text="🔇 Ads"
                android:textSize="13sp"
                android:backgroundTint="@color/btn_commercial"
                android:textColor="@color/text_on_accent"
                style="@style/Widget.MaterialComponents.Button"/>

            <Button
                android:id="@+id/btn_mode_auto"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:text="🤖 Auto"
                android:textSize="13sp"
                android:backgroundTint="@color/accent"
                android:textColor="@color/text_on_accent"
                style="@style/Widget.MaterialComponents.Button"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
