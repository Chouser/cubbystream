<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:baselineAligned="false"
    android:orientation="horizontal"
    android:background="@color/bg_dark">

    <!-- ===================================================================== -->
    <!-- LEFT COLUMN: controls                                                 -->
    <!-- ===================================================================== -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@color/bottom_bar_bg"
        android:elevation="4dp">

        <!-- Spinner + settings button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/header_bg"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical">

            <Spinner
                android:id="@+id/spinner_stream"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Settings"
                android:src="@android:drawable/ic_menu_preferences"
                app:tint="@color/text_secondary" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_play"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="@color/btn_play_color"
                android:enabled="false"
                android:nextFocusRight="@id/btn_stop"
                android:nextFocusDown="@id/btn_skip_to_live"
                android:text="▶ Play"
                android:textColor="@color/text_on_accent"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_stop"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:backgroundTint="@color/btn_stop_color"
                android:enabled="false"
                android:nextFocusLeft="@id/btn_play"
                android:nextFocusDown="@id/btn_skip_to_live"
                android:text="■ Stop"
                android:textColor="@color/text_on_accent"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Status / error text -->
        <TextView
            android:id="@+id/text_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- Energy / info panel (visible when stream active) -->
        <LinearLayout
            android:id="@+id/layout_info_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:background="@color/header_bg"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:visibility="invisible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/text_energy_level"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="monospace"
                    android:text="Level: —"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/text_mode_indicator"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text="Auto: Game"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/text_threshold"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="monospace"
                    android:gravity="end"
                    android:text="Thr: —"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp" />

            </LinearLayout>

            <ProgressBar
                android:id="@+id/progress_energy"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginBottom="4dp"
                android:max="100"
                android:progress="0" />

        </LinearLayout>

        <!-- Spacer pushes controls toward center/bottom -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:id="@+id/layout_seek_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="visible">

            <Button
                android:id="@+id/btn_skip_to_live"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:backgroundTint="@color/btn_live_color"
                android:nextFocusUp="@id/btn_play"
                android:nextFocusDown="@id/btn_pause"
                android:text="▶▶ Live"
                android:textColor="@color/text_on_accent"
                android:textSize="15sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_pause"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="@color/btn_pause_color"
                android:enabled="false"
                android:nextFocusRight="@id/btn_resume"
                android:nextFocusUp="@id/btn_skip_to_live"
                android:nextFocusDown="@id/btn_mode_game"
                android:text="⏸ Pause"
                android:textColor="@color/text_on_accent"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_resume"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:backgroundTint="@color/btn_play_color"
                android:nextFocusLeft="@id/btn_pause"
                android:nextFocusUp="@id/btn_skip_to_live"
                android:nextFocusDown="@id/btn_mode_auto"
                android:text="▶ Resume"
                android:textColor="@color/text_on_accent"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:gravity="center"
            android:letterSpacing="0.15"
            android:text="VOLUME MODE"
            android:textColor="@color/text_secondary"
            android:textSize="9sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_mode_game"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:backgroundTint="@color/btn_inactive"
                android:nextFocusRight="@id/btn_mode_ads"
                android:nextFocusUp="@id/btn_pause"
                android:text="🔊 Game"
                android:textColor="@color/text_on_accent"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_mode_ads"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:backgroundTint="@color/btn_inactive"
                android:nextFocusLeft="@id/btn_mode_game"
                android:nextFocusRight="@id/btn_mode_auto"
                android:nextFocusUp="@id/btn_pause"
                android:text="🔇 Ads"
                android:textColor="@color/text_on_accent"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_mode_auto"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:backgroundTint="@color/btn_inactive"
                android:nextFocusLeft="@id/btn_mode_ads"
                android:nextFocusUp="@id/btn_resume"
                android:text="🤖 Auto"
                android:textColor="@color/text_on_accent"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Controls block -->

    </LinearLayout>

    <!-- ===================================================================== -->
    <!-- RIGHT COLUMN: scoreboard + diamond                                    -->
    <!-- ===================================================================== -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_weight="1.5">

        <LinearLayout
            android:id="@+id/layout_scoreboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="@+id/layout_baseball_field"
            app:layout_constraintStart_toStartOf="@+id/layout_baseball_field"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/img_away_logo"
                    android:layout_width="50dp"
                    android:layout_height="50dp" />

                <TextView
                    android:id="@+id/text_away_abbr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="CHC"
                    android:textColor="@color/text_secondary"
                    android:textSize="9sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/text_away_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="12dp"
                android:layout_marginRight="20dp"
                android:text="7"
                android:textColor="@color/text_secondary"
                android:textSize="48sp" />

            <TextView
                android:id="@+id/text_count_outs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:text="▲9\nouts: ●●●\n3-2"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/text_home_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="12dp"
                android:text="1"
                android:textColor="@color/text_secondary"
                android:textSize="48sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/img_home_logo"
                    android:layout_width="50dp"
                    android:layout_height="50dp" />

                <TextView
                    android:id="@+id/text_home_abbr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="TEX"
                    android:textColor="@color/text_secondary"
                    android:textSize="9sp" />
            </LinearLayout>
        </LinearLayout>

    <!-- ===================================================================== -->
    <!-- Diamond -->
    <!-- ===================================================================== -->

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_baseball_field"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layout_scoreboard">

            <ImageView
                android:id="@+id/image_baseball_diamond"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginBottom="24dp"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:src="@drawable/bg_baseball_field"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintDimensionRatio="200:175"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/text_base1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="center"
                android:textColor="@color/text_on_accent"
                android:textSize="12sp"
                app:layout_constraintBottom_toTopOf="@+id/base1"
                app:layout_constraintEnd_toEndOf="@+id/base1"
                app:layout_constraintStart_toStartOf="@+id/base1" />

            <TextView
                android:id="@+id/text_base2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="center"
                android:textColor="@color/text_on_accent"
                android:textSize="12sp"
                app:layout_constraintBottom_toTopOf="@+id/base2"
                app:layout_constraintEnd_toEndOf="@+id/base2"
                app:layout_constraintStart_toStartOf="@+id/base2" />

            <TextView
                android:id="@+id/text_base3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="center"
                android:textColor="@color/text_on_accent"
                android:textSize="12sp"
                app:layout_constraintBottom_toTopOf="@+id/base3"
                app:layout_constraintEnd_toEndOf="@+id/base3"
                app:layout_constraintStart_toStartOf="@+id/base3" />

            <ImageView
                android:id="@+id/base1"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:src="@drawable/base_diamond"
                app:layout_constraintBottom_toBottomOf="@+id/image_baseball_diamond"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toEndOf="@+id/image_baseball_diamond"
                app:layout_constraintHorizontal_bias="0.84"
                app:layout_constraintStart_toStartOf="@+id/image_baseball_diamond"
                app:layout_constraintTop_toTopOf="@+id/image_baseball_diamond"
                app:layout_constraintVertical_bias="0.55"
                app:layout_constraintWidth_percent="0.06" />

            <ImageView
                android:id="@+id/base3"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:src="@drawable/base_diamond"
                app:layout_constraintBottom_toBottomOf="@+id/image_baseball_diamond"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toEndOf="@+id/image_baseball_diamond"
                app:layout_constraintHorizontal_bias="0.16"
                app:layout_constraintStart_toStartOf="@+id/image_baseball_diamond"
                app:layout_constraintTop_toTopOf="@+id/image_baseball_diamond"
                app:layout_constraintVertical_bias="0.55"
                app:layout_constraintWidth_percent="0.06" />

            <ImageView
                android:id="@+id/base2"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:src="@drawable/base_diamond"
                app:layout_constraintBottom_toBottomOf="@+id/image_baseball_diamond"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toEndOf="@+id/image_baseball_diamond"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="@+id/image_baseball_diamond"
                app:layout_constraintTop_toTopOf="@+id/image_baseball_diamond"
                app:layout_constraintVertical_bias="0.19"
                app:layout_constraintWidth_percent="0.06" />

            <TextView
                android:id="@+id/text_pitcher_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Rizzo\npitches: 99"
                android:textColor="@color/text_on_accent"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="@+id/image_baseball_diamond"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="@+id/image_baseball_diamond"
                app:layout_constraintTop_toBottomOf="@+id/img_pitcher_logo" />

            <ImageView
                android:id="@+id/img_pitcher_logo"
                android:layout_width="26dp"
                android:layout_height="26dp"
                app:layout_constraintBottom_toBottomOf="@+id/image_baseball_diamond"
                app:layout_constraintEnd_toEndOf="@+id/image_baseball_diamond"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="@+id/image_baseball_diamond"
                app:layout_constraintTop_toTopOf="@+id/image_baseball_diamond"
                app:layout_constraintVertical_bias="0.55" />

            <TextView
                android:id="@+id/text_batter_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:text="Ozzie Smith"
                android:textColor="@color/text_on_accent"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="@+id/image_baseball_diamond"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="@+id/image_baseball_diamond"
                app:layout_constraintTop_toBottomOf="@+id/img_batter_logo" />

            <ImageView
                android:id="@+id/img_batter_logo"
                android:layout_width="26dp"
                android:layout_height="26dp"
                app:layout_constraintBottom_toBottomOf="@+id/image_baseball_diamond"
                app:layout_constraintEnd_toEndOf="@+id/image_baseball_diamond"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="@+id/image_baseball_diamond"
                app:layout_constraintTop_toTopOf="@+id/image_baseball_diamond"
                app:layout_constraintVertical_bias="0.937" />

            <TextView
                android:id="@+id/btn_gameday_data"
                android:layout_width="48dp"
                android:layout_height="100dp"
                android:layout_marginStart="12dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="bottom|center"
                android:padding="8dp"
                android:text="Play\nby\nPlay"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                app:layout_constraintBottom_toBottomOf="@+id/image_baseball_diamond"
                app:layout_constraintStart_toStartOf="@+id/image_baseball_diamond" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

</LinearLayout>
