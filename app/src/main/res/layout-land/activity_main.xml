<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/bg_dark">

    <!-- ===================================================================== -->
    <!-- LEFT COLUMN: controls (1/3 width)                                      -->
    <!-- ===================================================================== -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@color/bottom_bar_bg"
        android:elevation="4dp">

        <!-- Spinner + settings button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/header_bg"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical">

            <Spinner
                android:id="@+id/spinner_stream"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp" />

            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_preferences"
                app:tint="@color/text_secondary" />

        </LinearLayout>

        <!-- Status / error text -->
        <TextView
            android:id="@+id/text_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- Energy / info panel (visible when stream active) -->
        <LinearLayout
            android:id="@+id/layout_info_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/header_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginTop="1dp"
            android:visibility="gone">

            <TextView
                android:visibility="gone"
                android:id="@+id/text_player_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:ellipsize="end"
                android:maxLines="1"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:visibility="gone"
                android:id="@+id/text_player_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/text_energy_level"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Level: —"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_secondary"/>

                <TextView
                    android:id="@+id/text_mode_indicator"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Auto: Game"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"/>

                <TextView
                    android:id="@+id/text_threshold"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Thr: —"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_secondary"
                    android:gravity="end"/>

            </LinearLayout>

            <ProgressBar
                android:id="@+id/progress_energy"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:layout_marginBottom="4dp"/>

        </LinearLayout>

        <!-- Spacer pushes controls toward center/bottom -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Controls block -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <!-- Play | Stop -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btn_play"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="▶ Play"
                    android:textSize="14sp"
                    android:enabled="false"
                    android:nextFocusRight="@id/btn_stop"
                    android:nextFocusDown="@id/btn_skip_to_live"
                    android:backgroundTint="@color/btn_play_color"
                    android:textColor="@color/text_on_accent"
                    style="@style/Widget.MaterialComponents.Button" />

                <Button
                    android:id="@+id/btn_stop"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="■ Stop"
                    android:textSize="14sp"
                    android:enabled="false"
                    android:nextFocusLeft="@id/btn_play"
                    android:nextFocusDown="@id/btn_skip_to_live"
                    android:backgroundTint="@color/btn_stop_color"
                    android:textColor="@color/text_on_accent"
                    style="@style/Widget.MaterialComponents.Button" />

            </LinearLayout>

            <!-- Skip to Live -->
            <LinearLayout
                android:id="@+id/layout_seek_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:visibility="visible">

                <Button
                    android:id="@+id/btn_skip_to_live"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="▶▶ Live"
                    android:textSize="15sp"
                    android:nextFocusUp="@id/btn_play"
                    android:nextFocusDown="@id/btn_pause"
                    android:backgroundTint="@color/btn_live_color"
                    android:textColor="@color/text_on_accent"
                    style="@style/Widget.MaterialComponents.Button"/>

            </LinearLayout>

            <!-- Pause | Resume -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <Button
                    android:id="@+id/btn_pause"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="⏸  Pause"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:enabled="false"
                    android:nextFocusUp="@id/btn_skip_to_live"
                    android:nextFocusRight="@id/btn_resume"
                    android:nextFocusDown="@id/btn_mode_game"
                    android:backgroundTint="@color/btn_pause_color"
                    android:textColor="@color/text_on_accent"
                    style="@style/Widget.MaterialComponents.Button"/>

                <Button
                    android:id="@+id/btn_resume"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="▶  Resume"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:nextFocusUp="@id/btn_skip_to_live"
                    android:nextFocusLeft="@id/btn_pause"
                    android:nextFocusDown="@id/btn_mode_auto"
                    android:backgroundTint="@color/btn_play_color"
                    android:textColor="@color/text_on_accent"
                    style="@style/Widget.MaterialComponents.Button"/>

            </LinearLayout>

            <!-- Volume mode label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="VOLUME MODE"
                android:textSize="9sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.15"
                android:gravity="center"
                android:layout_marginBottom="5dp"/>

            <!-- Game | Ads | Auto -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_mode_game"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="🔊 Game"
                    android:textSize="12sp"
                    android:textColor="@color/text_on_accent"
                    android:nextFocusUp="@id/btn_pause"
                    android:nextFocusRight="@id/btn_mode_ads"
                    android:backgroundTint="@color/btn_inactive"
                    style="@style/Widget.MaterialComponents.Button"/>

                <Button
                    android:id="@+id/btn_mode_ads"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:text="🔇 Ads"
                    android:textSize="12sp"
                    android:textColor="@color/text_on_accent"
                    android:nextFocusUp="@id/btn_pause"
                    android:nextFocusLeft="@id/btn_mode_game"
                    android:nextFocusRight="@id/btn_mode_auto"
                    android:backgroundTint="@color/btn_inactive"
                    style="@style/Widget.MaterialComponents.Button"/>

                <Button
                    android:id="@+id/btn_mode_auto"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="🤖 Auto"
                    android:textSize="12sp"
                    android:textColor="@color/text_on_accent"
                    android:nextFocusUp="@id/btn_resume"
                    android:nextFocusLeft="@id/btn_mode_ads"
                    android:backgroundTint="@color/btn_inactive"
                    style="@style/Widget.MaterialComponents.Button"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ===================================================================== -->
    <!-- RIGHT COLUMN: scoreboard + diamond (2/3 width)                         -->
    <!-- ===================================================================== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="2">

        <!-- Scoreboard -->
        <LinearLayout
            android:id="@+id/layout_scoreboard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/img_away_logo"
                    android:layout_width="32dp"
                    android:layout_height="32dp" />

                <TextView
                    android:id="@+id/text_score_line"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:textColor="@color/text_on_accent"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/img_home_logo"
                    android:layout_width="32dp"
                    android:layout_height="32dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/text_count_outs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Diamond frame -->
        <FrameLayout
            android:id="@+id/diamond_frame"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/layout_scoreboard"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/image_baseball_diamond"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:src="@drawable/bg_baseball_field"
                    android:scaleType="fitCenter"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/text_base1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center"
                    android:textColor="@color/text_on_accent"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toTopOf="@+id/base1"
                    app:layout_constraintEnd_toEndOf="@+id/base1"
                    app:layout_constraintStart_toStartOf="@+id/base1" />

                <TextView
                    android:id="@+id/text_base2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center"
                    android:textColor="@color/text_on_accent"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toTopOf="@+id/base2"
                    app:layout_constraintEnd_toEndOf="@+id/base2"
                    app:layout_constraintStart_toStartOf="@+id/base2" />

                <TextView
                    android:id="@+id/text_base3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center"
                    android:textColor="@color/text_on_accent"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toTopOf="@+id/base3"
                    app:layout_constraintEnd_toEndOf="@+id/base3"
                    app:layout_constraintStart_toStartOf="@+id/base3" />

                <ImageView
                    android:id="@+id/base1"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:src="@drawable/base_diamond"
                    app:layout_constraintWidth_percent="0.06"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintBottom_toBottomOf="@+id/image_baseball_diamond"
                    app:layout_constraintEnd_toEndOf="@+id/image_baseball_diamond"
                    app:layout_constraintHorizontal_bias="0.83"
                    app:layout_constraintStart_toStartOf="@+id/image_baseball_diamond"
                    app:layout_constraintTop_toTopOf="@+id/image_baseball_diamond"
                    app:layout_constraintVertical_bias="0.47" />

                <ImageView
                    android:id="@+id/base3"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:src="@drawable/base_diamond"
                    app:layout_constraintWidth_percent="0.06"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintBottom_toBottomOf="@+id/image_baseball_diamond"
                    app:layout_constraintEnd_toEndOf="@+id/image_baseball_diamond"
                    app:layout_constraintStart_toStartOf="@+id/image_baseball_diamond"
                    app:layout_constraintTop_toTopOf="@+id/image_baseball_diamond"
                    app:layout_constraintHorizontal_bias="0.17"
                    app:layout_constraintVertical_bias="0.47" />

                <ImageView
                    android:id="@+id/base2"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:src="@drawable/base_diamond"
                    app:layout_constraintWidth_percent="0.06"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintBottom_toBottomOf="@+id/image_baseball_diamond"
                    app:layout_constraintEnd_toEndOf="@+id/image_baseball_diamond"
                    app:layout_constraintStart_toStartOf="@+id/image_baseball_diamond"
                    app:layout_constraintTop_toTopOf="@+id/image_baseball_diamond"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintVertical_bias="0.17" />

                <TextView
                    android:id="@+id/text_pitcher_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/text_on_accent"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.498"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.482" />

                <TextView
                    android:id="@+id/text_batter_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:textColor="@color/text_on_accent"
                    app:layout_constraintBottom_toBottomOf="@+id/image_baseball_diamond"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.498"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/btn_gameday_data"
                    android:layout_width="44dp"
                    android:layout_height="99dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="bottom|center"
                    android:padding="8dp"
                    android:text="Play\nby\nPlay"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    app:layout_constraintBottom_toBottomOf="@+id/image_baseball_diamond"
                    app:layout_constraintStart_toStartOf="@+id/image_baseball_diamond" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>
