<?xml version="1.0" encoding="utf-8"?>
<!-- Shows a subtle highlight border when the view has D-pad focus; invisible otherwise. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <stroke android:width="2dp" android:color="@color/btn_live"/>
            <corners android:radius="4dp"/>
            <padding android:left="4dp" android:top="4dp"
                     android:right="4dp" android:bottom="4dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>
</selector>
